{
  "manifest_version": 3,
  "name": "YouTube Live Chat Assistant",
  "version": "1.0",
  "description": "Automates sending messages to YouTube Live Chat by fetching them from a custom API.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/live_chat*", "https://www.youtube.com/live_chat_replay*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
