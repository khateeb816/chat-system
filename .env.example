# =============================================
# Firebase Admin SDK (REQUIRED)
# =============================================
# Steps to get this:
# 1. Go to: https://console.firebase.google.com/project/chat-system-67471/settings/serviceaccounts/adminsdk
# 2. Click "Generate new private key"
# 3. Download the JSON file
# 4. Paste the ENTIRE contents of that file as a single line below
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"chat-system-67471","private_key_id":"REPLACE","private_key":"REPLACE","client_email":"REPLACE@chat-system-67471.iam.gserviceaccount.com","client_id":"REPLACE","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# =============================================
# JWT Secret (keep this secret!)
# =============================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
